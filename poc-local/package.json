{
  "name": "poc-local",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/mobile"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names API,EXPO \"npm:dev:api\" \"npm:dev:mobile\"",
    "dev:api": "npm run dev --workspace @rosi-home-poc/api",
    "dev:mobile": "npm run web --workspace @rosi-home-poc/mobile",
    "dev:mobile:lan": "npm run start:lan --workspace @rosi-home-poc/mobile",
    "dev:iphone": "concurrently --kill-others-on-fail --names API,EXPO \"npm:dev:api\" \"npm:dev:mobile:lan\"",
    "test": "npm run test --workspace @rosi-home-poc/api",
    "typecheck": "npm run typecheck --workspace @rosi-home-poc/api && npm run typecheck --workspace @rosi-home-poc/mobile",
    "build": "npm run build --workspace @rosi-home-poc/api && npm run export:web --workspace @rosi-home-poc/mobile",
    "poc:reset": "npm run reset --workspace @rosi-home-poc/api",
    "verify:evidence": "node scripts/verify-evidence.mjs"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
