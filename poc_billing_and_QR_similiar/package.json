{
  "name": "rosihome-core-poc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch src/server.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node src/server.js",
    "test": "node --test --test-concurrency=1"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "multer": "^2.0.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "vite": "^7.3.1"
  }
}
