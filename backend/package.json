{
  "name": "rosihome-backend",
  "version": "0.1.0",
  "private": true,
  "description": "RosiHome property management system — REST API backend (Node.js/Express + TypeScript + Drizzle + Supabase Postgres).",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate --config=src/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=src/drizzle.config.ts",
    "db:seed": "tsx src/db/seeds/seed.ts",
    "test": "vitest run",
    "test:api": "vitest run tests/api",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:local": "node scripts/test-database.mjs run",
    "test:db:up": "node scripts/test-database.mjs up",
    "test:db:down": "node scripts/test-database.mjs down",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.tests.json"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.20.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.24",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
