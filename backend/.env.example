# ---- Transactional email (Gmail + nodemailer SMTP) ----
# Use a Google App Password, NOT your normal Gmail password.
# See: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=RosiHome <your-gmail-address@gmail.com>
EMAIL_PROVIDER_API_KEY=

# ---- Mobile push notifications (Expo push service, not FCM) ----
# Optional. Only needed if you've enabled "Enhanced Security for Push
# Notifications" on your Expo project. Leave blank to send push
# notifications without it.
EXPO_ACCESS_TOKEN=

# ---- Private Supabase Storage (maintenance-photos bucket) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-server-side-service-role-key
