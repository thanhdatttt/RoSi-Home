# ---- Core ----
NODE_ENV=development
PORT=3000

# ---- Database (Supabase Postgres connection string) ----
# Use the pooled connection string for the API and the direct connection for migrations.
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_SECONDS=86400

# ---- Supabase Storage (file uploads) ----
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=replace-with-service-role-key

# ---- Push notifications (FCM HTTP v1, Firebase service-account JSON) ----
# Paste the ENTIRE downloaded service-account JSON as a single-line value.
# Backend-only secret: never commit and never expose to the mobile app.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- Transactional email ----
EMAIL_PROVIDER_API_KEY=replace-with-email-provider-key

# ---- Misc ----
APP_PUBLIC_URL=https://rosihome.app
