### ============================================================
### US-CHARGE-01 — Recurring property surcharges (create, list,
### update, deactivate). Landlord only; per-property.
### ============================================================
### Run in the "local" (or "device") environment from
### rest-client.env.json. The login block below captures
### @accessToken / @refreshToken for every request that follows.
### ============================================================
### ============================================================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{email}}",
  "password": "{{password}}"
}

### capture tokens
@accessToken = {{login.response.body.data.accessToken}}
@refreshToken = {{login.response.body.data.refreshToken}}

### ------------------------------------------------------------
### Resolve a property for the surcharge
### ------------------------------------------------------------
# @name createProperty
POST {{baseUrl}}/properties
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Charges Test Property",
  "address": "3 Charge Rd, District 1, HCMC"
}

@propertyId = {{createProperty.response.body.data.id}}

###

### ============================================================
### INTENDED TO SUCCEED
### ============================================================

### US-CHARGE-01 — Create a recurring surcharge
### Expect 201 { data:{ id, name, monthlyAmount, effectiveFrom, ... } }
POST {{baseUrl}}/charges/properties/{{propertyId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Internet",
  "monthlyAmount": 500000,
  "effectiveFrom": "2026-07-01"
}

@surchargeId = {{response.body.data.id}}

###

### US-CHARGE-01 — List surcharges for the property
### Expect 200 paginated; the Internet surcharge appears.
GET {{baseUrl}}/charges/properties/{{propertyId}}
Authorization: Bearer {{accessToken}}

###

### US-CHARGE-01 — Update the surcharge (prospective change)
### Expect 200 with updated values.
PATCH {{baseUrl}}/charges/{{surchargeId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "monthlyAmount": 550000,
  "name": "Internet (Upgraded)"
}

###

### US-CHARGE-01 — Deactivate the surcharge (soft delete)
### Expect 200 { data:{ success:true } } or updated view.
DELETE {{baseUrl}}/charges/{{surchargeId}}
Authorization: Bearer {{accessToken}}

###

### ============================================================
### INTENDED TO FAIL
### ============================================================

### Create with missing name (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/charges/properties/{{propertyId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "monthlyAmount": 500000,
  "effectiveFrom": "2026-07-01"
}

###

### Create with negative monthlyAmount (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/charges/properties/{{propertyId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Bad Surcharge",
  "monthlyAmount": -100,
  "effectiveFrom": "2026-07-01"
}

###

### Create with malformed effectiveFrom (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/charges/properties/{{propertyId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Bad Date",
  "monthlyAmount": 500000,
  "effectiveFrom": "07/01/2026"
}

###

### Update with empty body (expect 400 — at least one field required)
PATCH {{baseUrl}}/charges/{{surchargeId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

###

### Create surcharge on another landlord's property (expect 404)
POST {{baseUrl}}/charges/properties/{{otherLandlordPropertyId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Intruder",
  "monthlyAmount": 500000,
  "effectiveFrom": "2026-07-01"
}

###

### Unauthenticated create (expect 401 UNAUTHENTICATED)
POST {{baseUrl}}/charges/properties/{{propertyId}}
Content-Type: application/json

{
  "name": "No Auth",
  "monthlyAmount": 500000,
  "effectiveFrom": "2026-07-01"
}

###
