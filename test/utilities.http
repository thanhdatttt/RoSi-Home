### ============================================================
### US-UTILITY-01 / US-UTILITY-02 — Configure and view utility rates
### (Landlord only; per-property electricity + water rates).
### ============================================================
### Run in the "local" (or "device") environment from
### rest-client.env.json. The login block below captures
### @accessToken / @refreshToken for every request that follows.
### ============================================================
### ============================================================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{email}}",
  "password": "{{password}}"
}

### capture tokens
@accessToken = {{login.response.body.data.accessToken}}
@refreshToken = {{login.response.body.data.refreshToken}}

### ------------------------------------------------------------
### Resolve a property to configure rates on
### ------------------------------------------------------------
# @name createProperty
POST {{baseUrl}}/properties
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Utilities Test Property",
  "address": "2 Utility Ave, District 1, HCMC"
}

@propertyId = {{createProperty.response.body.data.id}}

###

### ============================================================
### INTENDED TO SUCCEED
### ============================================================

### US-UTILITY-01 — Configure Metered water rates
### Expect 201 { data:{ id, electricityRatePerKwh, waterBillingMethod, ... } }
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Metered",
  "waterRatePerM3": 20000,
  "effectiveFrom": "2026-07-01"
}

###

### US-UTILITY-01 — Configure Flat water rates (no waterRatePerM3)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Flat",
  "waterFlatAmountPerTenant": 100000,
  "effectiveFrom": "2026-08-01"
}

###

### US-UTILITY-02 — View effective utility rates for the property
### Expect 200 { data:{ ... current electricity + water rates ... } }
GET {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}

###

### ============================================================
### INTENDED TO FAIL
### ============================================================

### Missing electricityRatePerKwh (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "waterBillingMethod": "Flat",
  "waterFlatAmountPerTenant": 100000,
  "effectiveFrom": "2026-07-01"
}

###

### Negative rate (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": -5,
  "waterBillingMethod": "Flat",
  "waterFlatAmountPerTenant": 100000,
  "effectiveFrom": "2026-07-01"
}

###

### Invalid waterBillingMethod enum (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Monthly",
  "effectiveFrom": "2026-07-01"
}

###

### Metered without waterRatePerM3 (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Metered",
  "effectiveFrom": "2026-07-01"
}

###

### Malformed effectiveFrom date (expect 400 VALIDATION_ERROR)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Flat",
  "waterFlatAmountPerTenant": 100000,
  "effectiveFrom": "2026-13-99"
}

###

### Configure rates on another landlord's property (expect 404)
POST {{baseUrl}}/properties/{{otherLandlordPropertyId}}/utility-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Flat",
  "waterFlatAmountPerTenant": 100000,
  "effectiveFrom": "2026-07-01"
}

###

### Unauthenticated configure (expect 401 UNAUTHENTICATED)
POST {{baseUrl}}/properties/{{propertyId}}/utility-rates
Content-Type: application/json

{
  "electricityRatePerKwh": 3500,
  "waterBillingMethod": "Flat",
  "waterFlatAmountPerTenant": 100000,
  "effectiveFrom": "2026-07-01"
}

###
